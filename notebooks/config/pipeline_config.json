{
  "pipeline": {
    "name": "sales-analytics-pipeline",
    "description": "Real-time sales analytics pipeline with medallion architecture",
    "trigger_interval": "2 minutes",
    "partition_column": "event_date"
  },
  "bronze": {
    "source": {
      "type": "eventhub",
      "format": "json"
    },
    "target": {
      "catalog": "sales_catalog",
      "schema": "bronze",
      "table": "orders",
      "mode": "append"
    },
    "schema": {
      "order_id": "string",
      "customer_id": "string",
      "product_id": "string",
      "product_name": "string",
      "quantity": "int",
      "unit_price": "double",
      "total_price": "double",
      "region": "string",
      "order_timestamp": "timestamp",
      "event_date": "date",
      "ingestion_timestamp": "timestamp"
    }
  },
  "silver": {
    "source": {
      "catalog": "sales_catalog",
      "schema": "bronze",
      "table": "orders"
    },
    "target": {
      "catalog": "sales_catalog",
      "schema": "silver",
      "table": "orders",
      "mode": "merge"
    },
    "transformations": [
      "null_handling",
      "deduplication",
      "type_casting",
      "business_rules"
    ]
  },
  "gold": {
    "source": {
      "catalog": "sales_catalog",
      "schema": "silver",
      "table": "orders"
    },
    "aggregations": [
      {
        "name": "daily_revenue",
        "dimensions": ["region", "event_date"],
        "metrics": ["sum(total_price) as revenue", "count(*) as order_count"]
      },
      {
        "name": "top_products",
        "dimensions": ["product_id", "product_name"],
        "metrics": ["sum(total_price) as revenue", "sum(quantity) as units_sold"],
        "top_n": 10
      },
      {
        "name": "customer_ltv",
        "dimensions": ["customer_id"],
        "metrics": ["sum(total_price) as lifetime_value", "count(*) as order_count"],
        "window": "90 days"
      }
    ]
  }
}
