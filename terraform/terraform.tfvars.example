##############################################################################
# terraform.tfvars.example
# Copy this file to terraform.tfvars and fill in your real values.
# NEVER commit terraform.tfvars to Git — it contains secrets!
# The .gitignore file already excludes it.
##############################################################################

# ── Step 1: Your Azure credentials ───────────────────────────────────────────
# Find these in Azure Portal → Azure Active Directory → App registrations
# Or run: az ad sp create-for-rbac --name "tf-pipeline-sp" --role Contributor
subscription_id = "REPLACE-WITH-YOUR-SUBSCRIPTION-ID"
tenant_id       = "REPLACE-WITH-YOUR-TENANT-ID"
client_id       = "REPLACE-WITH-YOUR-SERVICE-PRINCIPAL-APP-ID"
client_secret   = "REPLACE-WITH-YOUR-SERVICE-PRINCIPAL-SECRET"

# ── Step 2: General settings ──────────────────────────────────────────────────
prefix      = "rtsa"     # 3-6 lowercase letters, makes resource names unique
location    = "eastus"   # Azure region — pick one closest to you
environment = "dev"

# ── Step 3: SQL password ──────────────────────────────────────────────────────
# Must be 8+ chars with uppercase, lowercase, digit, and symbol
sql_admin_password = "REPLACE-WITH-STRONG-PASSWORD@123"

# ── Optional: Override defaults for cost savings ────────────────────────────────
# Use 'trial' for 14 days free, then it becomes 'standard'
# databricks_sku            = "trial"

# Cheaper cluster (1 core, 3.5GB RAM) - good for dev/testing
# cluster_node_type         = "Standard_DS1_v2"
# cluster_min_workers       = 1
# cluster_max_workers      = 2
# cluster_autotermination_minutes = 15  # Faster termination = lower cost

# Cheapest Event Hubs (Basic tier)
# eventhub_sku             = "Basic"

# Cheapest storage (Locally Redundant)
# storage_replication      = "LRS"

# Cheapest SQL (Basic tier - 5 DTUs)
# sql_database_sku         = "Basic"
github_pat      = "REPLACE-WITH-YOUR-GITHUB-PERSONAL-ACCESS-TOKEN"
